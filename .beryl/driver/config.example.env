# Driver configuration. Copy to config.env and edit. config.env is gitignored.
# Source of truth for all tunables used by run.sh.

# --- Codex CLI invocation ---
# The headless Codex binary.
CODEX_BIN="codex"
# Model override (empty = default from Codex config). e.g. gpt-5-codex
CODEX_MODEL=""
# Config profile override (empty = default from Codex config).
CODEX_PROFILE=""
# Headless sessions must not wait for interactive approval prompts.
# Mapped to Codex config key approval_policy via `codex exec -c`.
CODEX_SANDBOX="workspace-write"
CODEX_APPROVAL="never"
# Optional additional `codex exec` flags, split by the shell. Examples:
# CODEX_EXTRA_ARGS="--color never --search"
CODEX_EXTRA_ARGS="--color never"

# --- Loop control ---
# Max implement<->verify attempts per task before the driver blocks and stops.
MAX_ATTEMPTS=4
# Seconds to wait between phase sessions (lets fs settle / servers restart).
PHASE_PAUSE=3
# Clear gitignored driver state/log runtime material after a successful unscoped full run.
# CLI precedence: --flush-on-complete or --no-flush-on-complete overrides this for one invocation.
FLUSH_ON_COMPLETE="${FLUSH_ON_COMPLETE:-true}"

# --- Repo / git ---
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# Branch the driver works on. It will create it from BASE_BRANCH if missing.
WORK_BRANCH="feat/agent-driver-build"
BASE_BRANCH="main"
# Commit, but NEVER push (explicit user requirement).
ALLOW_PUSH="false"

# --- Optional app stack used for runtime/browser verification ---
# auto: start the legacy backend/frontend verifier only when this repo has that stack.
# always: require the legacy verifier stack and block if it cannot start.
# never: skip stack startup; verifier must use repo checks and task-specific evidence.
VERIFY_STACK_MODE="auto"
# Use "auto" to allocate fresh free ports per run when the stack is started.
VERIFY_FRONTEND_PORT="auto"
VERIFY_BACKEND_PORT="auto"
# These are recalculated by the driver after auto ports are resolved.
VERIFY_BASE_URL="http://localhost:${VERIFY_FRONTEND_PORT}"
VERIFY_API_URL="http://localhost:${VERIFY_BACKEND_PORT}"
# SQLite DB the verify backend points at (copy of dev DB, so verification
# never mutates the canonical dev database).
VERIFY_DB="backend/stochron.driververify.db"
SOURCE_DB="backend/stochron.db"

# --- Rate limit handling ---
# Seconds to wait on first rate-limit hit (increases linearly on consecutive hits, caps at 12h).
RATE_LIMIT_COOLDOWN="${RATE_LIMIT_COOLDOWN:-900}"
# Max consecutive rate-limit hibernations per phase before blocking the task.
MAX_RATE_LIMIT_WAITS="${MAX_RATE_LIMIT_WAITS:-5}"

# --- Mock mode (for testing the driver itself) ---
# When DRIVER_MOCK=1, no real Codex sessions/servers run. A scripted fake responder
# drives the state machine so the control flow can be exercised deterministically.
DRIVER_MOCK="${DRIVER_MOCK:-0}"
